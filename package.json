{
  "name": "@alexminza/skills-setup",
  "version": "2026.6.20",
  "description": "OpenClaw plugin for running skill setup scripts.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist/",
    "src/",
    "scripts/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle-runtime.mjs && npm run check:runtime-imports",
    "check:runtime-imports": "node scripts/check-runtime-imports.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "yaml": "^2.8.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.5"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "openclaw": "2026.5.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.5",
      "minGatewayVersion": "2026.5.5"
    },
    "build": {
      "openclawVersion": "2026.5.5",
      "pluginSdkVersion": "2026.5.5"
    }
  }
}
