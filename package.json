{
  "name": "@alexminza/skills-setup",
  "version": "2026.6.20",
  "description": "Admin-only OpenClaw plugin for running trusted installed skill setup scripts.",
  "keywords": [
    "openclaw",
    "plugin",
    "skills",
    "setup",
    "gateway",
    "operator-admin"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexminza/openclaw-skills-setup.git"
  },
  "bugs": {
    "url": "https://github.com/alexminza/openclaw-skills-setup/issues"
  },
  "homepage": "https://github.com/alexminza/openclaw-skills-setup#readme",
  "files": [
    "dist/",
    "src/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle-runtime.mjs && npm run check:runtime-imports",
    "check:runtime-imports": "node scripts/check-runtime-imports.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "clawhub:publish": "node scripts/clawhub-publish.mjs",
    "clawhub:publish:dry-run": "node scripts/clawhub-publish.mjs --dry-run",
    "clawhub:validate:runtime": "clawhub package validate . --out .clawhub/package-validate-runtime --runtime --allow-execute",
    "clawhub:validate:runtime:openclaw": "clawhub package validate . --out .clawhub/package-validate-runtime-openclaw --runtime --allow-execute --openclaw ../../openclaw/openclaw",
    "clawhub:validate": "clawhub package validate . --out .clawhub/package-validate",
    "prepack": "npm run build",
    "release:verify": "node scripts/verify-release.mjs",
    "test": "vitest run"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.5"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.27.7",
    "openclaw": "2026.5.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.5",
      "minGatewayVersion": "2026.5.5"
    },
    "build": {
      "openclawVersion": "2026.5.5",
      "pluginSdkVersion": "2026.5.5"
    }
  }
}
