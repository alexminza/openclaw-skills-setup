{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Release: Prepare",
      "dependsOrder": "sequence",
      "dependsOn": [
        "NPM: Check",
        "NPM: Test",
        "NPM: Build",
        "ClawHub: Validate",
        "NPM: Pack Dry Run"
      ],
      "problemMatcher": []
    },
    {
      "label": "NPM: Check",
      "type": "shell",
      "command": "npm run check",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "NPM: Test",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "NPM: Build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "NPM: Pack Dry Run",
      "type": "shell",
      "command": "npm pack --dry-run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Release: Verify Version Tag",
      "type": "shell",
      "command": "npm run release:verify",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ClawHub: Validate",
      "type": "shell",
      "detail": "Docs: https://docs.openclaw.ai/clawhub/plugin-validation-fixes",
      "command": "npm run clawhub:validate",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ClawHub: Validate Runtime",
      "type": "shell",
      "detail": "Optional runtime validation. Imports plugin code in an isolated workspace.",
      "command": "npm run clawhub:validate:runtime",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ClawHub: Validate Runtime With OpenClaw",
      "type": "shell",
      "detail": "Optional runtime validation against OpenClaw local source code checkout.",
      "command": "npm run clawhub:validate:runtime:openclaw",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "ClawHub: Publish Dry Run",
      "type": "shell",
      "command": "npm run clawhub:publish:dry-run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": [
        "Release: Prepare",
        "Release: Verify Version Tag"
      ]
    },
    {
      "label": "ClawHub: Publish",
      "type": "shell",
      "command": "npm run clawhub:publish",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "dependsOn": [
        "ClawHub: Publish Dry Run"
      ]
    }
  ]
}
